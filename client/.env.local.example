# ── Contact & Newsletter Email ────────────────────────────────
# Use a Gmail account. Steps to get the App Password:
#   1. Go to myaccount.google.com → Security → 2-Step Verification → ON
#   2. Search "App passwords" → create one named "Salt Website"
#   3. Paste the 16-character password below (no spaces)
CONTACT_EMAIL_USER=your-gmail@gmail.com
CONTACT_EMAIL_PASS=xxxxxxxxxxxxxxxxxxxx

# Where to receive inquiry emails (optional — defaults to CONTACT_EMAIL_USER)
CONTACT_EMAIL_TO=sales@alsyedigroup.com
